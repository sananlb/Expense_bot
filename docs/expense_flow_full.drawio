    <mxGraphModel dx="1200" dy="1800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="2200" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="n1" value="User sends message" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="280" height="50" as="geometry"/></mxCell><mxCell id="n2" value="Expense router receives message&#xa;(bot/routers/expense.py)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="40" y="90" width="320" height="60" as="geometry"/></mxCell><mxCell id="n3" value="parse_expense_message&#xa;(bot/utils/expense_parser.py)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="40" y="170" width="320" height="60" as="geometry"/></mxCell><mxCell id="n4" value="Preprocess text:&#xa;- normalize, strip emoji&#xa;- convert words -&gt; numbers&#xa;- extract date/time/currency&#xa;- split amount/description" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="40" y="250" width="380" height="110" as="geometry"/></mxCell><mxCell id="n5" value="Amount found?" style="shape=rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="40" y="380" width="200" height="60" as="geometry"/></mxCell><mxCell id="n6" value="Not an expense / ask for amount&#xa;(exit handler)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="260" y="380" width="300" height="70" as="geometry"/></mxCell><mxCell id="n7" value="Build text_for_keywords&#xa;(remove amount, lowercase)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="40" y="470" width="320" height="60" as="geometry"/></mxCell><mxCell id="n8" value="Category from:&#xa;- user category names&#xa;- user keywords (whole-word)&#xa;- default keyword dict&#xa;(+ keyword usage increment)" style="shape=rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="40" y="550" width="380" height="100" as="geometry"/></mxCell><mxCell id="n9" value="Set category from user category&#xa;or default category key&#xa;(+ category_key)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="40" y="670" width="360" height="80" as="geometry"/></mxCell><mxCell id="n10" value="Text is number-only?" style="shape=rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="40" y="770" width="220" height="60" as="geometry"/></mxCell><mxCell id="n11" value="Set default category&#xa;(OTHER/DEFAULT)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="280" y="770" width="260" height="70" as="geometry"/></mxCell><mxCell id="n12" value="Use AI?&#xa;(no category OR category not in user list)" style="shape=rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="40" y="870" width="320" height="70" as="geometry"/></mxCell><mxCell id="n13" value="AI categorization (AISelector):&#xa;- user categories list&#xa;- recent categories&#xa;- provider + 1 fallback&#xa;- timeout" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="40" y="960" width="380" height="110" as="geometry"/></mxCell><mxCell id="n14" value="AI category matched&#xa;to user categories?" style="shape=rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="40" y="1090" width="260" height="70" as="geometry"/></mxCell><mxCell id="n15" value="Set category + category_key&#xa;ai_categorized=True&#xa;confidence/provider" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="40" y="1180" width="320" height="80" as="geometry"/></mxCell><mxCell id="n16" value="Final fallback:&#xa;if category None -&gt; default" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="40" y="1275" width="320" height="70" as="geometry"/></mxCell><mxCell id="n17" value="Create expense (services/expense.py):&#xa;- validate date range, amount&#xa;- category ownership&#xa;- limit 100/day&#xa;- set time&#xa;- save" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="40" y="1360" width="380" height="110" as="geometry"/></mxCell><mxCell id="n18" value="ai_categorized &amp; description?" style="shape=rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="40" y="1490" width="260" height="60" as="geometry"/></mxCell><mxCell id="n19" value="Celery learn_keywords_on_create:&#xa;extract words -&gt; spellcheck -&gt; filter_keywords_for_saving&#xa;remove duplicates across categories&#xa;add keywords, cleanup_old_keywords (&gt;1000)&#xa;check 50 keywords limit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="40" y="1570" width="420" height="130" as="geometry"/></mxCell><mxCell id="n20" value="Respond to user (message + UI)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="40" y="1720" width="320" height="60" as="geometry"/></mxCell><mxCell id="n30" value="User edits expense category" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="760" y="250" width="280" height="60" as="geometry"/></mxCell><mxCell id="n31" value="update_expense:&#xa;- validate profile/expense&#xa;- save fields" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGe